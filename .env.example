JWT_SECRET=change_me_to_a_long_random_string



# Local dev — use 127.0.0.1 (not localhost) for cookies/OAuth exact match

WEB_URL=http://127.0.0.1:3000



# Vercel production example:

# WEB_URL=https://your-frontend.vercel.app

# TWITTER_CALLBACK_URL=https://your-frontend.vercel.app/api/auth/twitter/callback

# (frontend rewrites /api/* to this backend — OR use backend URL directly)

# TWITTER_CALLBACK_URL=https://your-backend.vercel.app/api/auth/twitter/callback

# ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://preview-branch.vercel.app

# MOCK_TWITTER=false



# Twitter OAuth 2.0 (Web App — confidential client)

TWITTER_CLIENT_ID=

TWITTER_CLIENT_SECRET=

TWITTER_CALLBACK_URL=http://127.0.0.1:3000/api/auth/twitter/callback



# Local dev fallback (set false on Vercel production)

MOCK_TWITTER=true

